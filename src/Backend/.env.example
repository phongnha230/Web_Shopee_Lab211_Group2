# ========================================
# DATABASE CONFIGURATION
# ========================================
# Thay thế bằng chuỗi kết nối MongoDB của bạn
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.exxxxxx.mongodb.net/web_shoppe?retryWrites=true&w=majority

# ========================================
# JWT AUTHENTICATION
# ========================================
# Khóa bí mật JWT (ít nhất 32 ký tự)
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationAndValidation123456
# Thời gian hết hạn Access Token (ms) - 30 phút
JWT_EXPIRATION=1800000
# Thời gian hết hạn Refresh Token (ms) - 7 ngày
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# GOOGLE OAUTH2
# ========================================
# Lấy từ Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URI của frontend local sau khi login Google thành công
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
# Email dùng để gửi OTP
MAIL_USERNAME=your-email@gmail.com
# Mật khẩu ứng dụng (App Password) - KHÔNG PHẢI mật khẩu đăng nhập Gmail
MAIL_PASSWORD=your-16-char-app-password

# ========================================
# OTP CONFIGURATION
# ========================================
# Thời gian hết hạn OTP (ms) - 5 phút
OTP_EXPIRATION=300000

# ========================================
# LOCAL RUNTIME PROFILE
# ========================================
# Mặc định local nên dùng profile dev
SPRING_PROFILES_ACTIVE=dev

# ========================================
# LOCAL CORS CONFIGURATION
# ========================================
# Các origin frontend local được phép gọi API
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# ========================================
# AUTH RATE LIMIT STORE
# ========================================
# Chọn nơi lưu dữ liệu rate limit: mongo hoặc redis
AUTH_RATE_LIMIT_STORE=mongo

# ========================================
# REDIS CONFIGURATION (OPTIONAL)
# ========================================
# Chỉ cần set khi AUTH_RATE_LIMIT_STORE=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# CLOUDINARY CONFIGURATION
# ========================================
# Có thể copy từ .env.cloudinary.example nếu muốn tách riêng phần này
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
